// This is your Prisma schema file
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// User - Authentication and authorization
model User {
  id            String    @id @default(uuid())
  name          String
  email         String    @unique
  passwordHash  String
  role          String    @default("PORTFOLIO_LEAD") // PORTFOLIO_LEAD | EXECUTIVE | PMO
  isActive      Boolean   @default(true) // For account activation/deactivation control
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  lastLoginAt   DateTime?
  
  portfolios    Portfolio[]
}

// Portfolio - Defines the decision boundary
model Portfolio {
  id            String   @id @default(uuid())
  userId        String   // Owner of the portfolio
  name          String
  description   String?
  fiscalPeriod  String
  totalBudget   Float
  totalCapacity Int
  status        String   @default("DRAFT") // DRAFT | LOCKED
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  initiatives       Initiative[]
  scenarios         Scenario[]
  governanceRecords GovernanceDecisionRecord[]
  objectives        StrategicObjective[]
  roleCapacities    RoleCapacity[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

// StrategicObjective - Links initiatives to portfolio strategy
model StrategicObjective {
  id          String   @id @default(uuid())
  portfolioId String
  name        String
  description String?
  priority    Int      @default(1)
  createdAt   DateTime @default(now())

  portfolio   Portfolio   @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  initiatives Initiative[]

  @@index([portfolioId])
}

// Initiative - Atomic unit of decision-making
model Initiative {
  id                      String   @id @default(uuid())
  portfolioId             String
  objectiveId             String?  // Optional FK to StrategicObjective
  name                    String
  description             String?
  sponsor                 String
  deliveryOwner           String
  strategicAlignmentScore Int      // 1-5 integer (completeness gate)
  strategyScore           Float    @default(0) // 0-100 continuous (priority formula)
  estimatedValue          Float
  capexCost               Float    @default(0)
  opexCost                Float    @default(0)
  costOfDelay             Float    @default(0) // Weekly business cost of delay
  riskScore               Int      // 1-5
  lifecycleState          String   @default("IDEA") // IDEA | CONCEPT_APPROVED | PLANNED | EXECUTION | CLOSED | TERMINATED
  status                  String   @default("Proposed")
  isComplete              Boolean  @default(false)
  priorityScore           Float?   // Calculated by system
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
  
  portfolio         Portfolio           @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  objective         StrategicObjective? @relation(fields: [objectiveId], references: [id])
  capacityDemands   CapacityDemand[]
  scenarioDecisions ScenarioDecision[]
  risks             InitiativeRisk[]

  @@index([portfolioId])
  @@index([priorityScore])
  @@index([isComplete])
  @@index([lifecycleState])
  @@index([objectiveId])
}

// Role - Named role types for capacity tracking
model Role {
  id          String @id @default(uuid())
  name        String @unique // e.g. "Backend Developer", "Data Engineer"
  description String?

  capacityBuckets RoleCapacity[]
  capacityDemands CapacityDemand[]
}

// RoleCapacity - Available capacity per role per portfolio per period
model RoleCapacity {
  id             String   @id @default(uuid())
  portfolioId    String
  roleId         String
  availableUnits Int
  periodLabel    String   // e.g. "Q1 2026", "FY2026"
  createdAt      DateTime @default(now())

  portfolio Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  role      Role      @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@index([portfolioId])
  @@index([roleId])
}

// CapacityDemand - Role-based capacity requirements per initiative
model CapacityDemand {
  id           String  @id @default(uuid())
  initiativeId String
  role         String  // Free-text role name (always set for display)
  roleId       String? // Optional FK to Role model for structured validation
  units        Int
  
  initiative Initiative @relation(fields: [initiativeId], references: [id], onDelete: Cascade)
  roleRef    Role?      @relation(fields: [roleId], references: [id])

  @@index([initiativeId])
  @@index([roleId])
}

// InitiativeRisk - Risk register per initiative
model InitiativeRisk {
  id           String   @id @default(uuid())
  initiativeId String
  description  String
  probability  Float    // 0.0–1.0
  impact       Float    // 0.0–1.0
  exposure     Float    // Computed: probability × impact
  status       String   @default("OPEN") // OPEN | MITIGATED | CLOSED
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  initiative Initiative @relation(fields: [initiativeId], references: [id], onDelete: Cascade)

  @@index([initiativeId])
  @@index([status])
}

// Scenario - Clone of baseline portfolio state
model Scenario {
  id            String   @id @default(uuid())
  portfolioId   String
  name          String
  assumptions   String   // Mandatory per governance rules
  isBaseline    Boolean  @default(false)
  isFinalized   Boolean  @default(false)
  isRecommended Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  portfolio Portfolio          @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  decisions ScenarioDecision[]
  metrics   ScenarioMetrics?

  @@index([portfolioId])
  @@index([isFinalized])
  @@index([isRecommended])
}

// ScenarioMetrics - Stored scenario aggregates (never computed on-the-fly)
model ScenarioMetrics {
  id            String   @id @default(uuid())
  scenarioId    String   @unique
  totalValue    Float    @default(0)
  totalCapex    Float    @default(0)
  totalOpex     Float    @default(0)
  totalCost     Float    @default(0) // totalCapex + totalOpex
  totalCapacity Int      @default(0)
  avgRiskScore  Float    @default(0)
  fundedCount   Int      @default(0)
  pausedCount   Int      @default(0)
  stoppedCount  Int      @default(0)
  updatedAt     DateTime @updatedAt

  scenario Scenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
}

// Scenario Decision - Fund/Pause/Stop per initiative
model ScenarioDecision {
  id           String @id @default(uuid())
  scenarioId   String
  initiativeId String
  decision     String // FUND | PAUSE | STOP
  
  scenario     Scenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  initiative   Initiative @relation(fields: [initiativeId], references: [id], onDelete: Cascade)
  
  @@unique([scenarioId, initiativeId])
}

// Governance Decision Record - Immutable audit entity (BACKEND.md lines 66-69)
model GovernanceDecisionRecord {
  id          String   @id @default(uuid())
  portfolioId String
  actionType  String   // OVERRIDE | TERMINATION | FINALIZATION | SCENARIO_CREATION | LIFECYCLE_TRANSITION
  entityId    String
  entityType  String   // INITIATIVE | SCENARIO | PORTFOLIO
  rationale   String?
  userId      String   @default("system") // MVP: default to system
  metadata    String?  // JSON string for additional data
  createdAt   DateTime @default(now())
  
  portfolio   Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@index([portfolioId])
  @@index([actionType])
  @@index([createdAt])
}
